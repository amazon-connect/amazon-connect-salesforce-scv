<aura:component
        access="global"
        description="UtilityBarHelper"
        implements="lightning:utilityItem"
        controller="HelperController">

    <lightning:omniToolkitAPI aura:id="omniToolkit" />
    <lightning:utilityBarAPI aura:id="utilityBar"/>

    <aura:handler event="lightning:omniChannelLoginSuccess" action="{! c.onAgentLogin }" />

    <aura:handler name="init" value="{! this }" action="{! c.doInit }" />

    <aura:attribute name="baseUtilityLabel" type="String" />
    <aura:attribute name="agentStateLabel" type="String" />
    <aura:attribute name="agentState" type="String" default="" />
    <aura:attribute name="vfHost" type="String" />
    <aura:attribute name="amazonConnectInstanceName" type="String" />

    <aura:attribute name="utilityBarHelperFrameSrc" type="String" />

    <div class="slds-theme_default slds-show slds-color__background_gray-4" style="height: 100%; width:100%;">
        <div class="slds-align_absolute-center">
            <div class="slds-text-title_bold slds-m-around_medium">{! v.agentStateLabel}: {! v.agentState }<lightning:buttonIcon class="slds-m-left_small" iconName="utility:sort" variant="bare" size="large" alternativeText="Sync State" title="Sync State" onclick="{! c.toggleStatus }"/></div>
        </div>
        <iframe aura:id="utilityBarHelperFrame" src="{! v.utilityBarHelperFrameSrc }" style="display: none;"></iframe>
    </div>

</aura:component>
